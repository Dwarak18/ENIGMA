# ── Node ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*

# ── Build outputs ─────────────────────────────────────
dist/
build/

# ── Python caches ──────────────────────────────────────
__pycache__/
__pychache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
**/.pytest_cache/
.mypy_cache/
**/.mypy_cache/
.ruff_cache/
**/.ruff_cache/
.pyre/
**/.pyre/
.hypothesis/
**/.hypothesis/
.tox/
**/.tox/
.nox/
**/.nox/

# ── Python virtual environments ────────────────────────
venv/
**/venv/
.venv/
**/.venv/
env/
**/env/
*/venv/*
# ── Environment files (NEVER commit real secrets) ─────
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# ── Firmware build artifacts ──────────────────────────
firmware/build/
firmware/sdkconfig
firmware/managed_components/
firmware/.pytest_cache/

# ── Certificates (generate locally, use secrets manager) ──
nginx/certs/*.pem
nginx/certs/*.key
nginx/certs/*.crt

# ── IDE ────────────────────────────────────────────────
.vscode/launch.json
.idea/
*.suo
*.user

# ── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

