# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────
DATABASE_URL=postgresql://enigma:changeme@localhost:5432/enigma_db

# ── Security ──────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.example.com

# Max seconds a timestamp may differ from server time
MAX_TIMESTAMP_SKEW_S=60

# API rate limit (requests per 15-minute window per IP)
RATE_LIMIT_MAX=200

# ── Metrics (optional) ────────────────────────────────
# Set to "true" to expose /metrics endpoint (Prometheus)
ENABLE_METRICS=false

# ── WebSocket ─────────────────────────────────────────
# Transports: "websocket,polling" or "websocket"
WS_TRANSPORTS=websocket,polling

# ── Blockchain (Local Hardhat) ─────────────────────
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_RETRY_INTERVAL_MS=30000
BLOCKCHAIN_RETRY_BATCH_SIZE=20
